# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/saas_starter?schema=public"

# Secret used by Auth.js to sign session tokens.
# Generate one with:  npx auth secret   (it writes AUTH_SECRET into .env for you)
# Or paste any long random string here:
AUTH_SECRET="replace-with-a-long-random-string"
